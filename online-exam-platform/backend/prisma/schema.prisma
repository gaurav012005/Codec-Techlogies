// Prisma Schema for Online Examination & Proctoring Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  ADMIN
  EXAMINER
  STUDENT
}

enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTIPLE
  TRUE_FALSE
  SHORT_ANSWER
  FILL_IN_THE_BLANK
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum QuestionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  CLOSED
  RESULTS_PUBLISHED
  ARCHIVED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
  TERMINATED
}

enum ExamResult {
  PASS
  FAIL
  PENDING
}

enum ProctorEventType {
  TAB_SWITCH
  FACE_NOT_DETECTED
  MULTIPLE_FACES
  FULLSCREEN_EXIT
  SCREENSHOT_ATTEMPT
  COPY_PASTE_ATTEMPT
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum NotificationType {
  EXAM_ASSIGNED
  EXAM_REMINDER
  EXAM_STARTED
  EXAM_ENDING_SOON
  RESULTS_PUBLISHED
  FLAGGED_CHEATING
  NEW_USER_REGISTERED
  PASSWORD_RESET
  EXAM_SUBMITTED
  GRADING_COMPLETE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

// ==================== MODELS ====================

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          Role      @default(STUDENT)
  isActive      Boolean   @default(true) @map("is_active")
  avatarUrl     String?   @map("avatar_url")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  questionsCreated  Question[]
  examsCreated      Exam[]
  examAttempts      ExamAttempt[]
  notifications     Notification[]
  refreshTokens     RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Question {
  id              String          @id @default(uuid())
  questionText    String          @map("question_text")
  questionType    QuestionType    @map("question_type")
  difficultyLevel DifficultyLevel @map("difficulty_level")
  subject         String
  category        String?
  marks           Int
  negativeMarks   Float           @default(0) @map("negative_marks")
  explanation     String?
  imageUrl        String?         @map("image_url")
  correctAnswer   String?         @map("correct_answer")
  status          QuestionStatus  @default(DRAFT)
  createdById     String          @map("created_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  createdBy      User             @relation(fields: [createdById], references: [id])
  options        Option[]
  examQuestions  ExamQuestion[]
  studentAnswers StudentAnswer[]

  @@index([subject, difficultyLevel])
  @@index([createdById])
  @@index([status])
  @@map("questions")
}

model Option {
  id         String  @id @default(uuid())
  questionId String  @map("question_id")
  optionText String  @map("option_text")
  isCorrect  Boolean @default(false) @map("is_correct")
  sortOrder  Int     @default(0) @map("sort_order")

  // Relations
  question       Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentAnswers StudentAnswer[]

  @@map("options")
}

model Exam {
  id                String     @id @default(uuid())
  title             String
  description       String?
  subjectCategory   String     @map("subject_category")
  durationMinutes   Int        @map("duration_minutes")
  totalMarks        Int        @default(0) @map("total_marks")
  passingPercentage Float      @default(40) @map("passing_percentage")
  negativeMarking   Boolean    @default(false) @map("negative_marking")
  negativeMarkValue Float      @default(0) @map("negative_mark_value")
  startDatetime     DateTime   @map("start_datetime")
  endDatetime       DateTime   @map("end_datetime")
  maxAttempts       Int        @default(1) @map("max_attempts")
  examPassword      String?    @map("exam_password")
  shuffleQuestions  Boolean    @default(false) @map("shuffle_questions")
  shuffleOptions    Boolean    @default(false) @map("shuffle_options")
  showResultImmediately Boolean @default(true) @map("show_result_immediately")
  allowReview       Boolean    @default(false) @map("allow_review")
  adaptiveMode      Boolean    @default(false) @map("adaptive_mode")
  proctoringEnabled Boolean    @default(false) @map("proctoring_enabled")
  fullscreenRequired Boolean   @default(false) @map("fullscreen_required")
  proctorConfig     Json?      @map("proctor_config")
  status            ExamStatus @default(DRAFT)
  createdById       String     @map("created_by")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  // Relations
  createdBy     User           @relation(fields: [createdById], references: [id])
  examQuestions ExamQuestion[]
  examAttempts  ExamAttempt[]
  assignments   ExamAssignment[]

  @@index([status, startDatetime])
  @@index([createdById])
  @@map("exams")
}

model ExamQuestion {
  id            String @id @default(uuid())
  examId        String @map("exam_id")
  questionId    String @map("question_id")
  sectionNumber Int    @default(1) @map("section_number")
  sortOrder     Int    @default(0) @map("sort_order")

  // Relations
  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@unique([examId, questionId])
  @@map("exam_questions")
}

model ExamAssignment {
  id        String   @id @default(uuid())
  examId    String   @map("exam_id")
  studentId String   @map("student_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@map("exam_assignments")
}

model ExamAttempt {
  id            String        @id @default(uuid())
  examId        String        @map("exam_id")
  studentId     String        @map("student_id")
  attemptNumber Int           @default(1) @map("attempt_number")
  startedAt     DateTime      @default(now()) @map("started_at")
  submittedAt   DateTime?     @map("submitted_at")
  totalScore    Float?        @map("total_score")
  percentage    Float?
  result        ExamResult    @default(PENDING)
  status        AttemptStatus @default(IN_PROGRESS)
  adaptiveState Json?         @map("adaptive_state")
  ipAddress     String?       @map("ip_address")
  createdAt     DateTime      @default(now()) @map("created_at")

  // Relations
  exam           Exam            @relation(fields: [examId], references: [id])
  student        User            @relation(fields: [studentId], references: [id])
  studentAnswers StudentAnswer[]
  proctorLogs    ProctorLog[]
  riskScore      RiskScore?

  @@index([examId, studentId])
  @@map("exam_attempts")
}

model StudentAnswer {
  id               String    @id @default(uuid())
  attemptId        String    @map("attempt_id")
  questionId       String    @map("question_id")
  studentAnswer    String?   @map("student_answer")
  selectedOptionId String?   @map("selected_option_id")
  isCorrect        Boolean?  @map("is_correct")
  marksAwarded     Float?    @map("marks_awarded")
  examinerFeedback String?   @map("examiner_feedback")
  answeredAt       DateTime  @default(now()) @map("answered_at")

  // Relations
  attempt        ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question    @relation(fields: [questionId], references: [id])
  selectedOption Option?     @relation(fields: [selectedOptionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@map("student_answers")
}

model ProctorLog {
  id          String          @id @default(uuid())
  attemptId   String          @map("attempt_id")
  eventTime   DateTime        @default(now()) @map("event_time")
  eventType   ProctorEventType @map("event_type")
  riskLevel   RiskLevel       @map("risk_level")
  details     Json?
  snapshotUrl String?         @map("snapshot_url")

  // Relations
  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId, eventType])
  @@map("proctor_logs")
}

model RiskScore {
  id               String    @id @default(uuid())
  attemptId        String    @unique @map("attempt_id")
  tabSwitchScore   Float     @default(0) @map("tab_switch_score")
  faceMissingScore Float     @default(0) @map("face_missing_score")
  multiFaceScore   Float     @default(0) @map("multi_face_score")
  totalRiskScore   Float     @default(0) @map("total_risk_score")
  riskLevel        RiskLevel @default(LOW) @map("risk_level")
  calculatedAt     DateTime  @default(now()) @map("calculated_at")

  // Relations
  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@map("risk_scores")
}

model Notification {
  id          String              @id @default(uuid())
  userId      String              @map("user_id")
  type        NotificationType
  title       String
  message     String
  read        Boolean             @default(false)
  channel     NotificationChannel @default(IN_APP)
  scheduledAt DateTime?           @map("scheduled_at")
  sentAt      DateTime?           @map("sent_at")
  createdAt   DateTime            @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}
